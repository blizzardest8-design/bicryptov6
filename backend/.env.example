# Firebase Cloud Messaging (FCM) for Mobile Push Notifications (iOS/Android)
# Required for native mobile apps - get credentials from Firebase Console
FCM_PROJECT_ID=""
FCM_PRIVATE_KEY=""
FCM_CLIENT_EMAIL=""
FCM_SERVICE_ACCOUNT_PATH=""

# Web Push (VAPID) for Browser Push Notifications
# Works without Firebase - for Chrome, Firefox, Edge, Safari
# Generate keys: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT=""


