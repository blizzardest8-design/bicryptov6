modules = ["nodejs-22"]
[nix]
channel = "stable-25_05"

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Frontend"

[[workflows.workflow]]
name = "Frontend"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node scripts/replit-dev-env.js && (test -x frontend/node_modules/.bin/next || pnpm install --prefer-offline) && (node scripts/stub-backend.js &) && cd frontend && PORT=5000 NEXT_PUBLIC_FRONTEND_PORT=5000 NEXT_PUBLIC_BACKEND_PORT=4000 NODE_OPTIONS='--max-old-space-size=4096' pnpm exec next dev --webpack -H 0.0.0.0 -p 5000"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80
